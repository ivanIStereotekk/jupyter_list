   "source": [
    "def letter_counter(word:str):\n",
    "    lst = [*word]\n",
    "    result = []\n",
    "    for one in lst:\n",
    "        num = word.count(one)\n",
    "        result.append((num,one))     \n",
    "    return max(set(result))\n",
    "        \n",
    "    \n",
    "letter_counter(\"heeeeelloll\")\n",
    "\n",
    "\n"
   ]
  }
 ],
